Algoritmo "exercicio07"

Var
   numero, dobro, umTerco : Real

Inicio
     Escreva("Digite um número: ")
     Leia(numero)
     dobro <- numero * 2
     umTerco <- numero / 3
     EscrevaL("O dobro de ",numero," é: ", dobro)
     Escreva("Um terço de ",numero," é: ", umTerco)
Fimalgoritmo