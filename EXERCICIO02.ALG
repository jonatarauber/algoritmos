Algoritmo "exercicio03"

Var
    nome, mes : Caractere
    salario : Real
Inicio

   Escreva("Qual é o nome do funcionario? ")
   Leia(nome)
   Escreva("Qual é o sálario do funcíonario?")
   Leia(salario)
   Escreva("Qual é o męs?")
   Leia(mes)
   Escreva("O Funcíonario ",nome," tem um sálario de ",salario," no męs de ",mes)

Fimalgoritmo