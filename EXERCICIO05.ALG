Algoritmo "exercicio05"

Var
   nome : Caractere
   nota1, nota2, media : Real

Inicio
      Escreva("Qual é o nome do aluno?")
      Leia(nome)
      Escreva("Qual é a primeira nota?")
      Leia(nota1)
      Escreva("Qual é a segunda nota?")
      Leia(nota2)
      media <- (nota1 + nota2)/2
      Escreva("O aluno " ,nome, " tirou a média ",media)

Fimalgoritmo